<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Shared_Joy.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:Shared_Joy.Pages"
    Title="Shared Joy">

    <TabBar>
        <ShellContent
            Title="Dashboard"
            Icon="icon_dashboard"
            ContentTemplate="{DataTemplate pages:DashboardPage}"
            Route="DashboardPage" />

        <ShellContent
            Title="Queue"
            Icon="icon_queue"
            ContentTemplate="{DataTemplate pages:QueueManagementPage}"
            Route="QueueManagementPage" />

        <ShellContent
            Title="Settings"
            Icon="icon_settings"
            ContentTemplate="{DataTemplate pages:SettingsPage}"
            Route="SettingsPage" />
    </TabBar>

</Shell>
