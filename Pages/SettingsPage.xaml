<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:vm="clr-namespace:Shared_Joy.ViewModels"
             x:Class="Shared_Joy.Pages.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="Settings">


       <ScrollView>
              <VerticalStackLayout Padding="20"
                                   Spacing="16">

                     <!-- Spotify 配置区域 -->
                     <Label Text="Spotify Configuration"
                            FontAttributes="Bold"
                            FontSize="20"/>

                     <!-- Client ID 已配置：只显示脱敏状态 + 删除按钮 -->
                     <Border Padding="16"
                             Stroke="#1DB954"
                             StrokeShape="RoundRectangle 8"
                             IsVisible="{Binding IsClientIdSaved}">
                            <VerticalStackLayout Spacing="12">
                                   <Label Text="Client ID"
                                          FontAttributes="Bold"/>
                                   <HorizontalStackLayout Spacing="10"
                                                          VerticalOptions="Center">
                                          <Label Text="✅"
                                                 FontSize="18"
                                                 VerticalOptions="Center"/>
                                          <Label Text="Client ID is configured"
                                                 FontSize="14"
                                                 FontAttributes="Bold"
                                                 TextColor="#1DB954"
                                                 VerticalOptions="Center"/>
                                   </HorizontalStackLayout>
                                   <Label Text="The Client ID value is hidden for security. Remove it below to reconfigure."
                                          TextColor="Gray"
                                          FontSize="12"/>
                                   <Button Text="🗑 Remove Client ID"
                                           Command="{Binding ClearClientIdCommand}"
                                           BackgroundColor="#E74C3C"
                                           TextColor="White"
                                           IsEnabled="{Binding IsBusy, Converter={toolkit:InvertedBoolConverter}}"/>
                            </VerticalStackLayout>
                     </Border>

                     <!-- Client ID 未配置：显示输入框 + 保存按钮 -->
                     <Border Padding="16"
                             Stroke="LightGray"
                             StrokeShape="RoundRectangle 8"
                             IsVisible="{Binding IsClientIdSaved, Converter={toolkit:InvertedBoolConverter}}">
                            <VerticalStackLayout Spacing="12">
                                   <Label Text="Client ID"
                                          FontAttributes="Bold"/>
                                   <Label Text="Create an app at developer.spotify.com to get your Client ID."
                                          TextColor="Gray"
                                          FontSize="12"/>
                                   <Entry Text="{Binding ClientId}"
                                          Placeholder="Enter Spotify Client ID"
                                          IsEnabled="{Binding IsBusy, Converter={toolkit:InvertedBoolConverter}}"/>
                                   <Button Text="Save Client ID"
                                           Command="{Binding SaveClientIdCommand}"
                                           IsEnabled="{Binding IsBusy, Converter={toolkit:InvertedBoolConverter}}"/>
                            </VerticalStackLayout>
                     </Border>

                     <BoxView HeightRequest="1"
                              Color="LightGray"
                              Margin="0,4"/>

                     <!-- 账户区域 -->
                     <Label Text="Account"
                            FontAttributes="Bold"
                            FontSize="20"/>

                     <!-- 未登录状态 -->
                     <Border Padding="16"
                             Stroke="LightGray"
                             StrokeShape="RoundRectangle 8"
                             IsVisible="{Binding IsLoggedIn, Converter={toolkit:InvertedBoolConverter}}">
                            <VerticalStackLayout Spacing="12">
                                   <Label Text="Not signed in to Spotify"
                                          TextColor="Gray"
                                          FontSize="16"/>
                                   <Label Text="⚠️ Playback controls require a Spotify Premium account."
                                          TextColor="Orange"
                                          FontSize="12"/>
                                   <Button Text="Sign in to Spotify"
                                           Command="{Binding LoginCommand}"
                                           IsEnabled="{Binding IsBusy, Converter={toolkit:InvertedBoolConverter}}"/>
                            </VerticalStackLayout>
                     </Border>

                     <!-- 已登录状态 -->
                     <Border Padding="16"
                             Stroke="LightGray"
                             StrokeShape="RoundRectangle 8"
                             IsVisible="{Binding IsLoggedIn}">
                            <VerticalStackLayout Spacing="12">
                                   <HorizontalStackLayout Spacing="12">
                                          <!-- 用户头像 -->
                                          <Border StrokeShape="RoundRectangle 24"
                                                  StrokeThickness="0"
                                                  HeightRequest="48"
                                                  WidthRequest="48"
                                                  VerticalOptions="Center"
                                                  IsVisible="{Binding UserAvatarUrl, Converter={toolkit:IsStringNotNullOrWhiteSpaceConverter}}">
                                                 <Image Source="{Binding UserAvatarUrl}"
                                                        Aspect="AspectFill"
                                                        HeightRequest="48"
                                                        WidthRequest="48"/>
                                          </Border>
                                          <!-- 无头像时的占位符 -->
                                          <Border StrokeShape="RoundRectangle 24"
                                                  Stroke="LightGray"
                                                  StrokeThickness="1"
                                                  BackgroundColor="#E0E0E0"
                                                  HeightRequest="48"
                                                  WidthRequest="48"
                                                  VerticalOptions="Center"
                                                  IsVisible="{Binding UserAvatarUrl, Converter={toolkit:IsStringNullOrWhiteSpaceConverter}}">
                                                 <Label Text="🎵"
                                                        FontSize="20"
                                                        HorizontalOptions="Center"
                                                        VerticalOptions="Center"/>
                                          </Border>
                                          <VerticalStackLayout VerticalOptions="Center">
                                                 <Label Text="Signed in as"
                                                        TextColor="Gray"
                                                        FontSize="12"/>
                                                 <Label Text="{Binding UserName}"
                                                        FontSize="18"
                                                        FontAttributes="Bold"/>
                                          </VerticalStackLayout>
                                   </HorizontalStackLayout>
                                   <Button Text="Sign Out"
                                           Command="{Binding LogoutCommand}"
                                           BackgroundColor="Gray"
                                           TextColor="White"
                                           IsEnabled="{Binding IsBusy, Converter={toolkit:InvertedBoolConverter}}"/>
                            </VerticalStackLayout>
                     </Border>

                     <!-- 加载指示器 -->
                     <ActivityIndicator IsRunning="{Binding IsBusy}"
                                        IsVisible="{Binding IsBusy}"
                                        HorizontalOptions="Center"/>

                     <!-- 状态消息 -->
                     <Label Text="{Binding StatusMessage}"
                            IsVisible="{Binding StatusMessage, Converter={toolkit:IsStringNotNullOrWhiteSpaceConverter}}"
                            HorizontalOptions="Center"
                            FontSize="14"/>

                     <BoxView HeightRequest="1"
                              Color="LightGray"
                              Margin="0,4"/>

                     <!-- 帮助信息 -->
                     <Label Text="Setup Guide"
                            FontAttributes="Bold"
                            FontSize="20"/>

                     <Border Padding="16"
                             Stroke="LightGray"
                             StrokeShape="RoundRectangle 8">
                            <VerticalStackLayout Spacing="8">
                                   <Label Text="1. Go to developer.spotify.com and create a new app"
                                          FontSize="13"/>
                                   <Label Text="2. Set the Redirect URI to:"
                                          FontSize="13"/>
                                   <HorizontalStackLayout Spacing="4">
                                          <Label Text="   Android:"
                                                 FontSize="12"/>
                                          <Label Text="sharedjoy://callback"
                                                 FontSize="12"
                                                 FontFamily="OpenSansRegular"
                                                 TextColor="DodgerBlue"
                                                 TextDecorations="Underline">
                                                 <Label.GestureRecognizers>
                                                        <TapGestureRecognizer Tapped="OnCopyCallbackUri"/>
                                                 </Label.GestureRecognizers>
                                          </Label>
                                          <Label Text="📋"
                                                 FontSize="10"
                                                 VerticalOptions="Center"
                                                 TextColor="Gray"/>
                                   </HorizontalStackLayout>
                                   <HorizontalStackLayout Spacing="4">
                                          <Label Text="   Windows:"
                                                 FontSize="12"/>
                                          <Label Text="http://127.0.0.1:5432/callback"
                                                 FontSize="12"
                                                 FontFamily="OpenSansRegular"
                                                 TextColor="DodgerBlue"
                                                 TextDecorations="Underline">
                                                 <Label.GestureRecognizers>
                                                        <TapGestureRecognizer Tapped="OnCopyCallbackUri"/>
                                                 </Label.GestureRecognizers>
                                          </Label>
                                          <Label Text="📋"
                                                 FontSize="10"
                                                 VerticalOptions="Center"
                                                 TextColor="Gray"/>
                                   </HorizontalStackLayout>
                                   <Label Text="3. Copy the Client ID and paste it above"
                                          FontSize="13"/>
                                   <Label Text="4. Click 'Sign in to Spotify' to authorize"
                                          FontSize="13"/>
                            </VerticalStackLayout>
                     </Border>

              </VerticalStackLayout>
       </ScrollView>

</ContentPage>
