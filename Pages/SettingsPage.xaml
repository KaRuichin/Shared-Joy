<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:vm="clr-namespace:Shared_Joy.ViewModels"
             x:Class="Shared_Joy.Pages.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="Settings">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
            EventName="Appearing"
            Command="{Binding InitializeCommand}"/>
    </ContentPage.Behaviors>

    <ScrollView>
        <VerticalStackLayout Padding="20"
                Spacing="16">

            <!-- Spotify 配置区域 -->
            <Label Text="Spotify Configuration"
                    FontAttributes="Bold"
                    FontSize="20"/>

            <Frame Padding="16"
                    CornerRadius="8"
                    BorderColor="LightGray"
                    HasShadow="False">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Client ID"
                            FontAttributes="Bold"/>
                    <Label Text="Create an app at developer.spotify.com to get your Client ID."
                           TextColor="Gray"
                            FontSize="12"/>
                    <Entry Text="{Binding ClientId}"
                           Placeholder="Enter Spotify Client ID"
                           IsEnabled="{Binding IsBusy, Converter={toolkit:InvertedBoolConverter}}"/>
                    <Button Text="Save Client ID"
                            Command="{Binding SaveClientIdCommand}"
                            IsEnabled="{Binding IsBusy, Converter={toolkit:InvertedBoolConverter}}"/>
                </VerticalStackLayout>
            </Frame>

            <BoxView HeightRequest="1"
                    Color="LightGray"
                    Margin="0,4"/>

            <!-- 账户区域 -->
            <Label Text="Account"
                    FontAttributes="Bold"
                    FontSize="20"/>

            <!-- 未登录状态 -->
            <Frame Padding="16"
                    CornerRadius="8"
                    BorderColor="LightGray"
                    HasShadow="False"
                   IsVisible="{Binding IsLoggedIn, Converter={toolkit:InvertedBoolConverter}}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Not signed in to Spotify"
                            TextColor="Gray"
                            FontSize="16"/>
                    <Label Text="⚠️ Playback controls require a Spotify Premium account."
                           TextColor="Orange"
                            FontSize="12"/>
                    <Button Text="Sign in to Spotify"
                            Command="{Binding LoginCommand}"
                            IsEnabled="{Binding IsBusy, Converter={toolkit:InvertedBoolConverter}}"/>
                </VerticalStackLayout>
            </Frame>

            <!-- 已登录状态 -->
            <Frame Padding="16"
                    CornerRadius="8"
                    BorderColor="LightGray"
                    HasShadow="False"
                   IsVisible="{Binding IsLoggedIn}">
                <VerticalStackLayout Spacing="12">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="🎵"
                                FontSize="24"
                                VerticalOptions="Center"/>
                        <VerticalStackLayout>
                            <Label Text="Signed in as"
                                    TextColor="Gray"
                                    FontSize="12"/>
                            <Label Text="{Binding UserName}"
                                    FontSize="18"
                                    FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                    <Button Text="Sign Out"
                            Command="{Binding LogoutCommand}"
                            BackgroundColor="Gray"
                            TextColor="White"
                            IsEnabled="{Binding IsBusy, Converter={toolkit:InvertedBoolConverter}}"/>
                </VerticalStackLayout>
            </Frame>

            <!-- 加载指示器 -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center"/>

            <!-- 状态消息 -->
            <Label Text="{Binding StatusMessage}"
                   IsVisible="{Binding StatusMessage, Converter={toolkit:IsStringNotNullOrWhiteSpaceConverter}}"
                   HorizontalOptions="Center"
                   FontSize="14"/>

            <BoxView HeightRequest="1"
                    Color="LightGray"
                    Margin="0,4"/>

            <!-- 帮助信息 -->
            <Label Text="Setup Guide"
                    FontAttributes="Bold"
                    FontSize="20"/>

            <Frame Padding="16"
                    CornerRadius="8"
                    BorderColor="LightGray"
                    HasShadow="False">
                <VerticalStackLayout Spacing="8">
                    <Label Text="1. Go to developer.spotify.com and create a new app"
                            FontSize="13"/>
                    <Label Text="2. Set the Redirect URI to:"
                            FontSize="13"/>
                    <Label Text="   Android: sharedjoy://callback"
                            FontSize="12"
                            FontFamily="OpenSansRegular"
                            TextColor="Gray"/>
                    <Label Text="   Windows: http://127.0.0.1:5432/callback"
                            FontSize="12"
                            FontFamily="OpenSansRegular"
                            TextColor="Gray"/>
                    <Label Text="3. Copy the Client ID and paste it above"
                            FontSize="13"/>
                    <Label Text="4. Click 'Sign in to Spotify' to authorize"
                            FontSize="13"/>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
