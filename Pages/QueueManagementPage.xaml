<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Shared_Joy.ViewModels"
             x:Class="Shared_Joy.Pages.QueueManagementPage"
             x:DataType="vm:QueueManagementViewModel"
             Title="Queue">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20" RowSpacing="16">

        <!-- 标题 -->
        <Label Grid.Row="0" Text="Vote Queue Management" FontAttributes="Bold" FontSize="20" />

        <!-- 队列列表 -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding VoteQueue}" EmptyView="Queue is empty">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="8" Margin="0,4">
                        <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                <Label Text="{Binding Track.Name}" FontSize="16" />
                                <Label Text="{Binding Track.Artists}" TextColor="Gray" FontSize="12" />
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="{Binding VoteCount, StringFormat='🗳 {0}'}"
                                   FontAttributes="Bold" VerticalTextAlignment="Center" />
                            <Button Grid.Column="2" Text="⬆ Top" FontSize="12"
                                    CommandParameter="{Binding Track.Id}" />
                            <Button Grid.Column="3" Text="✕ Remove" FontSize="12"
                                    BackgroundColor="Red" TextColor="White"
                                    CommandParameter="{Binding Track.Id}" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- 底部操作 -->
        <HorizontalStackLayout Grid.Row="2" HorizontalOptions="Center" Spacing="16">
            <Button Text="Refresh" Command="{Binding RefreshQueueCommand}" />
            <Button Text="Clear Queue" Command="{Binding ClearQueueCommand}"
                    BackgroundColor="Orange" TextColor="White" />
        </HorizontalStackLayout>

    </Grid>

</ContentPage>
