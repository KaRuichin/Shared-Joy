<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Shared_Joy.ViewModels"
             xmlns:models="clr-namespace:Shared_Joy.Models"
             x:Class="Shared_Joy.Pages.DashboardPage"
             x:DataType="vm:DashboardViewModel"
             Title="Dashboard">

    <ScrollView>
        <VerticalStackLayout Padding="20"
                Spacing="16">

            <!-- 当前播放区域 -->
            <Border Stroke="{StaticResource Primary}"
                    Padding="12"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8">
                <Grid ColumnDefinitions="80,*"
                        ColumnSpacing="12">

                    <!-- 专辑封面 -->
                    <Border StrokeThickness="0"
                            StrokeShape="RoundRectangle 6"
                            HeightRequest="80"
                            WidthRequest="80"
                            IsVisible="{Binding HasTrack}">
                        <Image Source="{Binding AlbumImageUrl}"
                                Aspect="AspectFill"/>
                    </Border>

                    <!-- 无播放时的占位图标 -->
                    <Border StrokeThickness="0"
                            BackgroundColor="#2a2a2a"
                            StrokeShape="RoundRectangle 6"
                            HeightRequest="80"
                            WidthRequest="80"
                            IsVisible="{Binding HasTrack, Converter={StaticResource InvertedBoolConverter}}">
                        <Label Text="🎵"
                                FontSize="32"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"/>
                    </Border>

                    <!-- 歌曲信息 + 进度条 -->
                    <VerticalStackLayout Grid.Column="1"
                            Spacing="4"
                            VerticalOptions="Center">
                        <Label Text="Now Playing"
                                FontSize="12"
                                TextColor="Gray"/>

                        <!-- 有歌曲时显示曲目信息 -->
                        <Label Text="{Binding TrackName}"
                                FontSize="16"
                                FontAttributes="Bold"
                               LineBreakMode="TailTruncation"
                                MaxLines="1"
                               IsVisible="{Binding HasTrack}"/>
                        <Label Text="{Binding TrackArtists}"
                                FontSize="13"
                                TextColor="Gray"
                               LineBreakMode="TailTruncation"
                                MaxLines="1"
                               IsVisible="{Binding HasTrack}"/>
                        <Label Text="{Binding AlbumName}"
                                FontSize="12"
                                TextColor="DarkGray"
                               LineBreakMode="TailTruncation"
                                MaxLines="1"
                               IsVisible="{Binding HasTrack}"/>

                        <!-- 无歌曲时显示提示 -->
                        <Label Text="Nothing playing"
                                FontSize="14"
                                TextColor="Gray"
                               IsVisible="{Binding HasTrack, Converter={StaticResource InvertedBoolConverter}}"/>

                        <!-- 进度条 -->
                        <ProgressBar Progress="{Binding ProgressRatio}"
                                ProgressColor="{StaticResource Primary}"
                                     HeightRequest="4"
                                Margin="0,4,0,0"
                                     IsVisible="{Binding HasTrack}"/>

                        <!-- 进度时间 + 设备名 -->
                        <Grid ColumnDefinitions="*,Auto"
                                IsVisible="{Binding HasTrack}">
                            <Label Text="{Binding ProgressText}"
                                    FontSize="11"
                                    TextColor="Gray"/>
                            <Label Grid.Column="1"
                                    Text="{Binding DeviceName, StringFormat='🔊 {0}'}"
                                   FontSize="11"
                                    TextColor="Gray"/>
                        </Grid>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- 播放控制 -->
            <HorizontalStackLayout HorizontalOptions="Center"
                    Spacing="16">
                <Button Text="{Binding PlayPauseButtonText}"
                        Command="{Binding TogglePlaybackCommand}"
                        WidthRequest="120"/>
                <Button Text="⏭ Next"
                        Command="{Binding SkipNextCommand}"
                        WidthRequest="100"/>
            </HorizontalStackLayout>

            <!-- QR 码与 PIN 码 -->
            <Border Stroke="{StaticResource Primary}"
                    Padding="12"
                    StrokeThickness="1">
                <VerticalStackLayout Spacing="8"
                        HorizontalOptions="Center">
                    <Label Text="Scan to Join"
                            FontAttributes="Bold"
                            FontSize="16"
                            HorizontalTextAlignment="Center"/>
                    <Image Source="{Binding QrCodeImage}"
                            HeightRequest="200"
                            WidthRequest="200"/>
                    <Label Text="{Binding PinCode}"
                            FontSize="32"
                            FontAttributes="Bold"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="{Binding GuestCount, StringFormat='Guests Online: {0}'}"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Border>

            <!-- 会话控制 -->
            <HorizontalStackLayout HorizontalOptions="Center"
                    Spacing="16">
                <Button Text="Start Session"
                        Command="{Binding StartSessionCommand}"
                        IsVisible="{Binding IsSessionActive, Converter={StaticResource InvertedBoolConverter}}"/>
                <Button Text="End Session"
                        Command="{Binding EndSessionCommand}"
                        IsVisible="{Binding IsSessionActive}"
                        BackgroundColor="Red"
                        TextColor="White"/>
            </HorizontalStackLayout>

            <!-- 投票队列 -->
            <Label Text="Vote Queue"
                    FontAttributes="Bold"
                    FontSize="18"/>
            <CollectionView ItemsSource="{Binding VoteQueue}"
                    EmptyView="No votes yet">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:VoteItem">
                        <Border Padding="8"
                                Margin="0,4"
                                Stroke="LightGray"
                                StrokeThickness="1">
                            <HorizontalStackLayout Spacing="12">
                                <Label Text="{Binding Track.Name}"
                                        FontSize="16"
                                       VerticalTextAlignment="Center"/>
                                <Label Text="{Binding Track.Artists}"
                                        TextColor="Gray"
                                       VerticalTextAlignment="Center"/>
                                <Label Text="{Binding VoteCount, StringFormat='🗳 {0}'}"
                                       FontAttributes="Bold"
                                        VerticalTextAlignment="Center"
                                       HorizontalOptions="End"/>
                            </HorizontalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
